# Required: shared PIN for reception staff login.
RECEPTION_PIN=change-this-pin

# Optional: Bun server listen port.
PORT=3000

# Optional: SQLite database path. Use a persistent volume path in production.
DATABASE_PATH=data/reception.sqlite

# Optional: set to production when deployed behind HTTPS.
NODE_ENV=production

# Optional: auth cookie settings.
AUTH_COOKIE_NAME=reception_auth
AUTH_COOKIE_MAX_AGE_SECONDS=604800
