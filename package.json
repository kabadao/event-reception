{
  "name": "kabutomushi-reception",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "bun run build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 execute kabutomushi-reception --local --file=./schema.sql",
    "d1:migrate:remote": "wrangler d1 execute kabutomushi-reception --remote --file=./schema.sql",
    "preview": "wrangler dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "wrangler": "^4.87.0"
  }
}
